{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "ES6", "ESNext"], // 关键：识别浏览器全局对象
    "outDir": "./dist",
    "rootDir": "./src",
    "types": [], // 清空Node.js类型，避免冲突
    "jsx": "preserve"
  },
  "include": ["./src/**/*"], // 仅编译前端src目录
  "exclude": ["node_modules", "test", "scripts", "artifacts", "cache"]
}